{
  "name": "m5ls5e.com",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build": "npx vite build",
    "clean": "rm -rf dist",
    "format": "npx oxfmt src",
    "format:check": "npx oxfmt --check src",
    "lint": "npx oxlint src",
    "prebuild": "npm run clean",
    "preview": "npx vite preview",
    "start": "npx wrangler pages dev -- npx vite serve",
    "test": "npm run format:check && npm run lint"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "repository": {
    "url": "https://github.com/mikesprague/m5ls5e-com"
  },
  "engines": {
    "node": ">= 18.x",
    "npm": ">= 8.x"
  },
  "packageManager": "npm@11.17.0",
  "license": "MIT",
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "7.3.0",
    "@fortawesome/fontawesome-svg-core": "7.3.0",
    "bulma": "1.0.4",
    "cheerio": "1.2.0"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "8.0.0",
    "autoprefixer": "10.5.2",
    "cssnano": "8.0.2",
    "cz-git": "1.13.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "postcss": "8.5.19",
    "postcss-cli": "11.0.1",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "undici": "^8.4.1"
  },
  "browserslist": {
    "development": [
      "last 1 version"
    ],
    "production": [
      "> 1%",
      "last 2 versions",
      "not ie <= 10"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.3.1",
    "npm": "11.17.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "@parcel/watcher@2.5.6": true,
    "workerd@1.20260617.1": true
  }
}
